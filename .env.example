# ─── STRIPE ───────────────────────────────────────────────────────────────────
# Clés disponibles sur https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret — obtenu via `stripe listen --forward-to localhost:3000/api/stripe-webhook`
# ou dans Dashboard > Webhooks après avoir créé le webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── MOLLIE ───────────────────────────────────────────────────────────────────
# Clé disponible sur https://my.mollie.com/dashboard/developers/api-keys
# Utiliser test_... pour les tests, live_... pour la production
MOLLIE_API_KEY=test_...

# ─── RESEND ───────────────────────────────────────────────────────────────────
# Clé disponible sur https://resend.com/api-keys
# Domaine d'envoi : barbaluxe.be (à configurer dans Resend)
RESEND_API_KEY=re_...

# ─── CONFIGURATION ────────────────────────────────────────────────────────────
# Email de l'équipe pour recevoir une copie des commandes (optionnel)
STORE_EMAIL=contact@barbaluxe.be

# Injecté automatiquement par Vercel en production
# VERCEL_URL=barbaluxe.be
